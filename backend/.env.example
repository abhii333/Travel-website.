# Google Sheets integration for LOCAL DEVELOPMENT.
# Copy this file to backend/.env (real file is git-ignored) and fill in real values.
# See GOOGLE-SHEETS-SETUP.md for the full step-by-step.

# The long ID from the Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEET_ID=

# Tab name inside the sheet. Defaults to "Bookings" if unset.
# GOOGLE_SHEET_TAB_NAME=Bookings

# Full Google Cloud service account JSON, base64-encoded.
# Generate locally with:
#   base64 -i service-account.json | tr -d '\n'
# (paste the result on a single line, no line breaks)
GOOGLE_CREDENTIALS_BASE64=
